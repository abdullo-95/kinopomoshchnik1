    async function askAICinema(query) {
        if (!query.trim()) return;
        
        addAIMessage(query, true);
        aiInput.value = '';
        
        showTypingIndicator();
        
        try {
            // Используем бесплатный API для получения информации о фильмах
            const searchQuery = encodeURIComponent(query);
            const response = await fetch(`https://www.omdbapi.com/?apikey=8f38d9e1&t=${searchQuery}&plot=full`);
            
            if (response.ok) {
                const data = await response.json();
                if (data.Response === "True") {
                    const rating = data.imdbRating;
                    const stars = rating >= 8.0 ? '⭐'.repeat(Math.floor(rating)) : '';
                    const answer = `🎬 **${data.Title}** (${data.Year})\n\n📖 **Сюжет:** ${data.Plot}\n\n⭐ **Рейтинг IMDB:** ${rating}/10 ${stars}\n\n🎭 **Жанр:** ${data.Genre}\n\n🎬 **Режиссёр:** ${data.Director}\n\n👥 **Актёры:** ${data.Actors}\n\n💰 **Бюджет:** ${data.BoxOffice || 'не указан'}\n\n🏆 **Награды:** ${data.Awards || 'нет информации'}`;
                    removeTypingIndicator();
                    addAIMessage(answer);
                    return;
                }
            }
            
            // Fallback: локальная база популярных фильмов с высоким рейтингом
            const topMoviesDB = {
                "побег из шоушенка": "Побег из Шоушенка (1994) - Рейтинг: 9.3/10. Сюжет: Банкир Энди Дюфрейн осуждён за убийство жены и её любовника. В тюрьме Шоушенк он дружит с Эллисом 'Редом' Реддингом и доказывает, что надежда - это сила, способная разрушить любые стены.",
                "крестный отец": "Крёстный отец (1972) - Рейтинг: 9.2/10. Сюжет: Патриарх мафиозной семьи Дона Вито Корлеоне отходит от дел, передавая власть своему младшему сыну Майклу.",
                "тёмный рыцарь": "Тёмный рыцарь (2008) - Рейтинг: 9.0/10. Сюжет: Бэтмен, лейтенант Джим Гордон и прокурор Харви Дент объединяются, чтобы искоренить преступность в Готэме, но на пути встаёт безумный гений Джокер.",
                "форрест гамп": "Форрест Гамп (1994) - Рейтинг: 8.8/10. Сюжет: Парень с низким IQ становится свидетелем важнейших событий XX века и доказывает, что любовь и верность превыше всего.",
                "начало": "Начало (2010) - Рейтинг: 8.8/10. Сюжет: Профессиональный вор Кобб внедряется в сны людей, чтобы украсть секреты. Ему предлагают стереть долг за внедрение идеи в подсознание наследника корпорации."
            };
            
            const queryLower = query.toLowerCase();
            let found = false;
            for (const [key, value] of Object.entries(topMoviesDB)) {
                if (queryLower.includes(key)) {
                    removeTypingIndicator();
                    addAIMessage(value);
                    found = true;
                    break;
                }
            }
            
            if (!found) {
                removeTypingIndicator();
                addAIMessage("🎬 Я могу рассказать о любом популярном фильме! Попробуйте спросить:\n• Расскажи про Побег из Шоушенка\n• Что за фильм Интерстеллар?\n• Топ лучших фильмов всех времён\n• Какой фильм с высоким рейтингом посмотреть?");
            }
            
        } catch (error) {
            console.error("AI Error:", error);
            removeTypingIndicator();
            addAIMessage("🤖 Немного помогу! Вот несколько фильмов с рейтингом выше 8.0:\n\n1. Побег из Шоушенка (9.3)\n2. Крёстный отец (9.2)\n3. Тёмный рыцарь (9.0)\n4. Форрест Гамп (8.8)\n5. Начало (8.8)\n\nЗадайте конкретный вопрос про любой фильм!");
        }
    }

    aiBtn.addEventListener('click', () => {
        aiModal.classList.toggle('show');
    });
    
    aiCloseBtn.addEventListener('click', () => {
        aiModal.classList.remove('show');
    });
    
    aiSendBtn.addEventListener('click', () => {
        askAICinema(aiInput.value);
    });
    
    aiInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') askAICinema(aiInput.value);
    });

    // Обработчики событий
    document.getElementById('findBtn').onclick = performSearch;
    document.getElementById('randomBtn').onclick = randomMovie;
    document.getElementById('resetFinderBtn').onclick = () => {
        selected = { genre: null, mood: null, era: null, duration: null };
        document.querySelectorAll('.opt-btn').forEach(b => b.classList.remove('opt-active'));
        document.getElementById('resultBox').innerHTML = '👇 Выберите параметры и нажмите кнопку';
    };
    document.getElementById('clearHistoryBtn')?.addEventListener('click', () => {
        watchHistory = [];
        localStorage.setItem('watchHistory_v5', JSON.stringify(watchHistory));
        renderHistory();
    });
    document.getElementById('updateProfileBtn')?.addEventListener('click', updateProfile);
    document.getElementById('searchInput')?.addEventListener('input', searchByTitle);
    document.getElementById('doLoginBtn').onclick = login;
    document.getElementById('doRegisterBtn').onclick = register;
    document.getElementById('logoutBtn').onclick = logout;

    updateUIForUser();
    showFinderPanel();
</script>
</body>
</html>
