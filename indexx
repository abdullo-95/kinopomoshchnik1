<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Кинонавигатор PRO — 100000+ фильмов с AI ассистентом</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .tab-btn {
            background: rgba(255, 255, 255, 0.1);
            border: none;
            padding: 10px 20px;
            border-radius: 60px;
            color: white;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.2s;
        }

        .tab-btn.active {
            background: #f5c518;
            color: #1e1b2f;
            font-weight: bold;
        }

        .card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 48px;
            padding: 28px 24px;
            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.15);
            margin-bottom: 20px;
        }

        h1 {
            font-size: 1.6rem;
            text-align: center;
            color: #fff;
            margin-bottom: 8px;
        }

        .sub {
            text-align: center;
            color: #ccc;
            margin-bottom: 24px;
            font-size: 0.8rem;
        }

        .input-group {
            margin-bottom: 18px;
        }

        .input-group label {
            display: block;
            color: #f5c518;
            margin-bottom: 6px;
            font-weight: 500;
            font-size: 0.9rem;
        }

        .input-group input {
            width: 100%;
            padding: 12px 16px;
            border-radius: 60px;
            border: none;
            background: rgba(255, 255, 255, 0.15);
            color: white;
            font-size: 0.95rem;
            outline: none;
        }

        .input-group input::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

        .password-wrapper {
            position: relative;
        }

        .password-wrapper input {
            width: 100%;
            padding: 12px 50px 12px 16px;
            border-radius: 60px;
            border: none;
            background: rgba(255, 255, 255, 0.15);
            color: white;
            font-size: 0.95rem;
            outline: none;
        }

        .toggle-password {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            font-size: 1.2rem;
            background: none;
            border: none;
            color: #f5c518;
        }

        .btn {
            width: 100%;
            padding: 12px;
            border-radius: 60px;
            border: none;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
            margin-top: 10px;
        }

        .btn-primary {
            background: #f5c518;
            color: #1e1b2f;
        }

        .btn-secondary {
            background: rgba(255,255,255,0.2);
            color: white;
        }

        .btn-random {
            background: rgba(255,255,255,0.15);
            color: #f5c518;
            border: 1px solid #f5c518;
        }

        .question-card {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 28px;
            padding: 18px;
            margin-bottom: 18px;
        }

        .question {
            font-weight: 600;
            font-size: 1rem;
            color: #f5c518;
            margin-bottom: 10px;
        }

        .options {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .opt-btn {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 6px 14px;
            border-radius: 60px;
            font-size: 0.8rem;
            color: #f0f0f0;
            cursor: pointer;
            transition: 0.2s;
        }

        .opt-btn:hover, .opt-active {
            background: #f5c518;
            color: #1e1b2f;
        }

        .result-box {
            background: #0a0820e0;
            border-radius: 32px;
            padding: 20px;
            text-align: center;
            border: 1px solid rgba(245, 197, 24, 0.5);
            margin-top: 20px;
        }

        .movies-grid {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .movie-card {
            background: rgba(0,0,0,0.5);
            border-radius: 24px;
            padding: 15px;
            text-align: left;
            border: 1px solid rgba(245,197,24,0.3);
            position: relative;
            display: flex;
            gap: 15px;
            transition: transform 0.2s;
        }

        .movie-card:hover {
            transform: translateX(5px);
        }

        .movie-poster {
            width: 80px;
            height: 120px;
            border-radius: 12px;
            object-fit: cover;
            background: linear-gradient(135deg, #1e1b2f, #0f0c29);
            flex-shrink: 0;
        }

        .movie-info {
            flex: 1;
        }

        .favorite-btn {
            position: absolute;
            top: 15px;
            right: 15px;
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: #aaa;
            transition: 0.2s;
            z-index: 10;
        }

        .favorite-btn.active {
            color: #f5c518;
        }

        .movie-title {
            font-size: 1.2rem;
            font-weight: 800;
            color: #f5c518;
            margin-bottom: 5px;
            padding-right: 40px;
        }

        .movie-meta {
            font-size: 0.75rem;
            color: #aaa;
            margin-bottom: 10px;
        }

        .watch-links {
            display: flex;
            gap: 12px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .watch-link {
            display: inline-block;
            padding: 6px 16px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: bold;
            font-size: 0.8rem;
            transition: 0.2s;
        }

        .ivi-link {
            background: #ff5e00;
            color: white;
        }

        .youtube-link {
            background: #ff0000;
            color: white;
        }

        .search-box {
            margin-bottom: 20px;
        }

        .search-box input {
            width: 100%;
            padding: 14px 20px;
            border-radius: 60px;
            border: none;
            background: rgba(255,255,255,0.15);
            color: white;
            font-size: 1rem;
            outline: none;
        }

        .profile-info {
            background: rgba(0,0,0,0.3);
            border-radius: 30px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .error-msg {
            color: #ffaa66;
            font-size: 0.8rem;
            margin-top: 8px;
        }

        .success-msg {
            color: #88ff88;
            font-size: 0.8rem;
            margin-top: 8px;
        }

        .found-count {
            background: #f5c518;
            color: #1e1b2f;
            padding: 5px 12px;
            border-radius: 60px;
            font-size: 0.8rem;
            font-weight: bold;
            display: inline-block;
            margin-bottom: 15px;
        }

        .btn-group {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        /* AI Assistant Button */
        .ai-assistant-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #f5c518, #ff6b35);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            z-index: 1000;
            transition: all 0.3s ease;
            border: none;
            font-size: 28px;
        }

        .ai-assistant-btn:hover {
            transform: scale(1.1);
        }

        /* AI Modal */
        .ai-modal {
            position: fixed;
            bottom: 100px;
            right: 30px;
            width: 380px;
            max-width: calc(100vw - 40px);
            background: rgba(15, 12, 41, 0.98);
            backdrop-filter: blur(20px);
            border-radius: 28px;
            border: 1px solid rgba(245, 197, 24, 0.3);
            box-shadow: 0 10px 40px rgba(0,0,0,0.4);
            z-index: 1001;
            display: none;
            flex-direction: column;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .ai-modal.show {
            display: flex;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .ai-header {
            padding: 15px 18px;
            background: linear-gradient(135deg, #f5c51820, #ff6b3520);
            border-bottom: 1px solid rgba(245,197,24,0.2);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .ai-header h3 {
            color: #f5c518;
            font-size: 1rem;
        }

        .ai-close {
            background: none;
            border: none;
            color: #fff;
            font-size: 24px;
            cursor: pointer;
            opacity: 0.7;
        }

        .ai-messages {
            height: 350px;
            overflow-y: auto;
            padding: 15px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .ai-message {
            max-width: 85%;
            padding: 10px 14px;
            border-radius: 20px;
            font-size: 0.85rem;
            line-height: 1.4;
        }

        .ai-message.bot {
            background: rgba(255,255,255,0.1);
            color: #fff;
            align-self: flex-start;
            border-bottom-left-radius: 4px;
        }

        .ai-message.user {
            background: #f5c518;
            color: #1e1b2f;
            align-self: flex-end;
            border-bottom-right-radius: 4px;
        }

        .ai-input-area {
            padding: 15px;
            border-top: 1px solid rgba(255,255,255,0.1);
            display: flex;
            gap: 10px;
        }

        .ai-input-area input {
            flex: 1;
            padding: 10px 15px;
            border-radius: 40px;
            border: none;
            background: rgba(255,255,255,0.15);
            color: white;
            outline: none;
        }

        .ai-input-area button {
            background: #f5c518;
            border: none;
            padding: 8px 18px;
            border-radius: 40px;
            cursor: pointer;
            font-weight: bold;
        }

        .typing-indicator {
            display: flex;
            gap: 4px;
            padding: 8px 12px;
        }

        .typing-indicator span {
            width: 6px;
            height: 6px;
            background: #f5c518;
            border-radius: 50%;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 1; }
        }

        @media (max-width: 550px) {
            .card { padding: 20px; }
            .tabs { gap: 5px; }
            .tab-btn { padding: 6px 12px; font-size: 0.75rem; }
            .btn-group { flex-direction: column; }
            .movie-card { flex-direction: column; align-items: center; text-align: center; }
            .movie-poster { width: 100px; height: 150px; }
            .favorite-btn { top: 5px; right: 5px; }
            .ai-modal { width: calc(100vw - 40px); right: 20px; bottom: 90px; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="tabs" id="tabs"></div>

    <!-- Панель поиска фильмов -->
    <div id="finderPanel" class="card">
        <h1>🎬 Кинонавигатор PRO</h1>
