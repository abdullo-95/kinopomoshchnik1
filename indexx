        <h3 style="margin-top: 25px; color:#f5c518;">⭐ Избранные фильмы</h3>
        <div id="favoritesList" style="margin-top: 15px;"></div>
    </div>

    <!-- Панель истории -->
    <div id="historyPanel" class="card" style="display: none;">
        <h1>📜 История просмотров</h1>
        <div class="sub">Фильмы, которые вы искали ранее</div>
        <div id="historyList" style="max-height: 400px; overflow-y: auto;"></div>
        <button class="btn btn-secondary" id="clearHistoryBtn">🗑️ Очистить историю</button>
    </div>
</div>

<!-- AI Assistant Button & Modal -->
<button class="ai-assistant-btn" id="aiAssistantBtn">🤖</button>
<div class="ai-modal" id="aiModal">
    <div class="ai-header">
        <h3>🎬 AI Кинопомощник</h3>
        <button class="ai-close" id="aiCloseBtn">×</button>
