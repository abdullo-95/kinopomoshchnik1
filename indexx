    function findSimilarMovies(answers, count = 5) {
        let filtered = moviesData.filter(m => 
            m.genre === answers.genre && 
            m.mood === answers.mood && 
            m.era === answers.era && 
            m.duration === answers.duration &&
            !lastShownMovies.includes(m.id)
        );
        
        if (filtered.length < count) {
            const more = moviesData.filter(m => 
                m.genre === answers.genre && 
                m.mood === answers.mood &&
                !lastShownMovies.includes(m.id)
            );
            filtered = [...new Map([...filtered, ...more].map(m => [m.id, m])).values()];
        }
        
        if (filtered.length < count) {
            const evenMore = moviesData.filter(m => m.genre === answers.genre && !lastShownMovies.includes(m.id));
            filtered = [...new Map([...filtered, ...evenMore].map(m => [m.id, m])).values()];
        }
        
        if (filtered.length < count) {
            const allAvailable = moviesData.filter(m => !lastShownMovies.includes(m.id));
            filtered = [...filtered, ...allAvailable];
        }
        
        const shuffled = [...filtered];
        for (let i = shuffled.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
        }
        
        const selectedMovies = shuffled.slice(0, count);
        lastShownMovies = selectedMovies.map(m => m.id);
        if (lastShownMovies.length > 20) lastShownMovies = lastShownMovies.slice(-20);
        
        return selectedMovies;
    }

