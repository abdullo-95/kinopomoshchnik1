        <div class="sub">Создайте аккаунт за 30 секунд</div>
        <div class="input-group">
            <label>Логин *</label>
            <input type="text" id="regUsername" placeholder="Придумайте логин">
        </div>
        <div class="input-group password-wrapper">
            <label>Пароль *</label>
            <input type="password" id="regPassword" placeholder="Придумайте пароль">
            <button class="toggle-password" onclick="togglePassword('regPassword')">👁️</button>
        </div>
        <div class="input-group">
            <label>📱 Номер телефона *</label>
            <input type="tel" id="regPhone" placeholder="+7 123 456 78 90 или +992 123 456 789">
        </div>
        <div class="input-group">
            <label>📧 Email (необязательно)</label>
            <input type="email" id="regEmail" placeholder="email@example.com">
        </div>
        <button class="btn btn-secondary" id="generatePasswordBtn">🔑 Сгенерировать пароль</button>
        <button class="btn btn-primary" id="doRegisterBtn">Зарегистрироваться</button>
        <div id="regError" class="error-msg"></div>
        <div id="regSuccess" class="success-msg"></div>
    </div>

    <!-- Панель профиля -->
    <div id="profilePanel" class="card" style="display: none;">
        <h1>👤 Мой профиль</h1>
        <div class="sub">Управление аккаунтом</div>
        <div class="profile-info" id="profileInfo"></div>
        <div class="input-group">
